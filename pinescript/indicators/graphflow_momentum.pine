// @version=5
// © GraphFlow Platform — Momentum Composite Indicator v2.1
indicator("GraphFlow Momentum [GF]", shorttitle="GF Momentum",
          overlay=false, max_bars_back=500, precision=1)

// ── Inputs ───────────────────────────────────────────────────────────────────
grp_rsi    = "RSI Settings"
grp_macd   = "MACD Settings"
grp_stoch  = "Stochastic Settings"
grp_disp   = "Display Settings"

rsiLen     = input.int(14,   "RSI Length",      group=grp_rsi,  minval=2)
rsiOB      = input.int(70,   "Overbought",       group=grp_rsi,  minval=50, maxval=90)
rsiOS      = input.int(30,   "Oversold",         group=grp_rsi,  minval=10, maxval=50)

macdFast   = input.int(12,   "Fast Length",      group=grp_macd, minval=2)
macdSlow   = input.int(26,   "Slow Length",      group=grp_macd, minval=2)
macdSig    = input.int(9,    "Signal Length",    group=grp_macd, minval=2)

stochLen   = input.int(14,   "Stoch Length",     group=grp_stoch, minval=2)
smoothK    = input.int(3,    "Smooth %K",        group=grp_stoch, minval=1)
smoothD    = input.int(3,    "Smooth %D",        group=grp_stoch, minval=1)

showSignals = input.bool(true, "Show Buy/Sell Signals", group=grp_disp)
showBg      = input.bool(true, "Show Zone Background",  group=grp_disp)

// ── Calculations ──────────────────────────────────────────────────────────────
rsiVal     = ta.rsi(close, rsiLen)
[macdLine, sigLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSig)
stochK     = ta.sma(ta.stoch(close, high, low, stochLen), smoothK)
stochD     = ta.sma(stochK, smoothD)
atrVal     = ta.atr(14)

// Normalize components to -100/+100 scale
rsiNorm    = (rsiVal - 50) * 2
stochNorm  = (stochK  - 50) * 2
macdNorm   = math.sign(macdLine) * math.min(math.abs(macdLine / atrVal * 25), 100)

// Weighted composite
composite  = rsiNorm * 0.35 + stochNorm * 0.30 + macdNorm * 0.35
composite_smooth = ta.ema(composite, 3)

// Signal conditions
obLevel    = float(rsiOB - 50) * 2
osLevel    = float(rsiOS - 50) * 2

buySignal  = ta.crossover(composite_smooth, osLevel)  and composite_smooth < 0
sellSignal = ta.crossunder(composite_smooth, obLevel) and composite_smooth > 0

// ── Background Zones ──────────────────────────────────────────────────────────
var overbought_zone  = color.new(#ef4444, 90)
var oversold_zone    = color.new(#22c55e, 90)
var neutral_zone     = color.new(#6366f1, 97)

bgColor = showBg ? (
  composite_smooth > obLevel  ? overbought_zone :
  composite_smooth < osLevel  ? oversold_zone   :
  neutral_zone
) : na

bgcolor(bgColor)

// ── Plots ─────────────────────────────────────────────────────────────────────
compColor  = composite_smooth > 0 ? color.new(#22c55e, 0) : color.new(#ef4444, 0)
plot(composite_smooth, "Composite", color=compColor, linewidth=2)
plot(composite_smooth, "Composite Fill", color=color.new(compColor, 80), linewidth=1, style=plot.style_area)

hline(obLevel, "Overbought",  color.new(#ef4444, 40), linestyle=hline.style_dashed, linewidth=1)
hline(osLevel, "Oversold",    color.new(#22c55e, 40), linestyle=hline.style_dashed, linewidth=1)
hline(0,       "Zero",        color.new(#6b7280, 40), linestyle=hline.style_solid,  linewidth=1)

// Signal markers
plotshape(showSignals and buySignal,  "BUY",  shape.triangleup,   location.bottom, #22c55e, size=size.small, text="BUY",  textcolor=#22c55e)
plotshape(showSignals and sellSignal, "SELL", shape.triangledown, location.top,    #ef4444, size=size.small, text="SELL", textcolor=#ef4444)

// ── Info Table ────────────────────────────────────────────────────────────────
var table infoTable = table.new(position.top_right, 2, 5, bgcolor=color.new(#0f1117, 10), border_color=color.new(#374151, 50), border_width=1, frame_color=color.new(#374151, 50), frame_width=1)
if barstate.islast
    table.cell(infoTable, 0, 0, "GraphFlow Momentum", text_color=#6366f1, text_size=size.small, bgcolor=color.new(#6366f1, 90))
    table.cell(infoTable, 1, 0, "v2.1", text_color=#6366f1, text_size=size.small, bgcolor=color.new(#6366f1, 90))
    table.cell(infoTable, 0, 1, "Composite", text_color=#9ca3af, text_size=size.tiny)
    table.cell(infoTable, 1, 1, str.tostring(math.round(composite_smooth, 1)), text_color=composite_smooth > 0 ? #22c55e : #ef4444, text_size=size.tiny)
    table.cell(infoTable, 0, 2, "RSI", text_color=#9ca3af, text_size=size.tiny)
    table.cell(infoTable, 1, 2, str.tostring(math.round(rsiVal, 1)), text_color=rsiVal > rsiOB ? #ef4444 : rsiVal < rsiOS ? #22c55e : #9ca3af, text_size=size.tiny)
    table.cell(infoTable, 0, 3, "Stoch %K", text_color=#9ca3af, text_size=size.tiny)
    table.cell(infoTable, 1, 3, str.tostring(math.round(stochK, 1)), text_color=#9ca3af, text_size=size.tiny)
    table.cell(infoTable, 0, 4, "Signal", text_color=#9ca3af, text_size=size.tiny)
    table.cell(infoTable, 1, 4, composite_smooth > obLevel ? "OVERBOUGHT" : composite_smooth < osLevel ? "OVERSOLD" : "NEUTRAL", text_color=composite_smooth > obLevel ? #ef4444 : composite_smooth < osLevel ? #22c55e : #6b7280, text_size=size.tiny)

// ── Alerts ────────────────────────────────────────────────────────────────────
if buySignal
    alert("GraphFlow: BUY signal on " + syminfo.ticker + " (" + timeframe.period + ") — Composite crossed OS", alert.freq_once_per_bar_close)
if sellSignal
    alert("GraphFlow: SELL signal on " + syminfo.ticker + " (" + timeframe.period + ") — Composite crossed OB", alert.freq_once_per_bar_close)
if ta.crossover(composite_smooth, 0)
    alert("GraphFlow: " + syminfo.ticker + " composite turned BULLISH", alert.freq_once_per_bar_close)
if ta.crossunder(composite_smooth, 0)
    alert("GraphFlow: " + syminfo.ticker + " composite turned BEARISH", alert.freq_once_per_bar_close)

alertcondition(buySignal,  "GF BUY Signal (Legacy)",  "GraphFlow: BUY signal")
alertcondition(sellSignal, "GF SELL Signal (Legacy)", "GraphFlow: SELL signal")
