// @version=5
// © GraphFlow Platform — Smart Money Concepts (SMC) Indicator v2.0
indicator("GraphFlow SMC [GF]", overlay=true, max_bars_back=1000,
          max_lines_count=500, max_labels_count=500, max_boxes_count=200)

// ── Inputs ────────────────────────────────────────────────────────────────────
swing_len   = input.int(10,    "Swing Length",        minval=3, maxval=50)
show_bos    = input.bool(true, "Show Break of Structure (BOS)")
show_choch  = input.bool(true, "Show Change of Character (CHoCH)")
show_fvg    = input.bool(true, "Show Fair Value Gaps (FVG)")
show_ob     = input.bool(true, "Show Order Blocks (OB)")
fvg_extend  = input.int(20,   "Extend FVG Boxes",    minval=1, maxval=100)
ob_extend   = input.int(20,   "Extend OB Boxes",     minval=1, maxval=100)
ob_cleanup  = input.bool(true, "Cleanup Mitigated OBs")

// ── Swing Detection ───────────────────────────────────────────────────────────
swingHigh  = ta.pivothigh(high, swing_len, swing_len)
swingLow   = ta.pivotlow(low,  swing_len, swing_len)

var float lastSwingH    = na
var float lastSwingL    = na
var int   lastSwingHBar  = na
var int   lastSwingLBar  = na
var bool  trend_bullish  = false

if not na(swingHigh)
    lastSwingH    := swingHigh
    lastSwingHBar := bar_index - swing_len

if not na(swingLow)
    lastSwingL    := swingLow
    lastSwingLBar := bar_index - swing_len

// ── Structure Break logic ─────────────────────────────────────────────────────
bos_bull   = ta.crossover(close, lastSwingH)
bos_bear   = ta.crossunder(close, lastSwingL)
choch_bull = not trend_bullish and bos_bull
choch_bear = trend_bullish and bos_bear

// ── FVG Detection with Cleanup ─────────────────────────────────────────────────
var fvg_boxes = array.new_box()
bull_fvg = low > high[2] and close[1] > high[2]
bear_fvg = high < low[2] and close[1] < low[2]

if show_fvg and bull_fvg
    b = box.new(bar_index - 2, low, bar_index + fvg_extend, high[2],
                bgcolor=color.new(#22c55e, 90), border_color=color.new(#22c55e, 70))
    array.push(fvg_boxes, b)

if show_fvg and bear_fvg
    b = box.new(bar_index - 2, low[2], bar_index + fvg_extend, high,
                bgcolor=color.new(#ef4444, 90), border_color=color.new(#ef4444, 70))
    array.push(fvg_boxes, b)

// ── Order Blocks ──────────────────────────────────────────────────────────────
var ob_boxes = array.new_box()
bull_ob = bos_bull and close[1] < open[1]
bear_ob = bos_bear and close[1] > open[1]

if show_ob and bull_ob
    b = box.new(bar_index - 1, math.min(open[1], close[1]), bar_index + ob_extend, math.max(open[1], close[1]),
                bgcolor=color.new(#6366f1, 85), border_color=color.new(#6366f1, 50),
                text="Bull OB", text_color=color.new(#6366f1, 20), text_size=size.tiny)
    array.push(ob_boxes, b)

if show_ob and bear_ob
    b = box.new(bar_index - 1, math.min(open[1], close[1]), bar_index + ob_extend, math.max(open[1], close[1]),
                bgcolor=color.new(#f59e0b, 85), border_color=color.new(#f59e0b, 50),
                text="Bear OB", text_color=color.new(#f59e0b, 20), text_size=size.tiny)
    array.push(ob_boxes, b)

// ── Structure Visualization ────────────────────────────────────────────────────
if bos_bull and not na(lastSwingH)
    label.new(bar_index, high, choch_bull ? "CHoCH" : "BOS", color=color.new(#22c55e, 0), textcolor=color.white, style=label.style_label_down, size=size.tiny)
    line.new(lastSwingHBar, lastSwingH, bar_index, lastSwingH, color=color.new(#22c55e, 50), style=line.style_dashed)
    trend_bullish := true

if bos_bear and not na(lastSwingL)
    label.new(bar_index, low, choch_bear ? "CHoCH" : "BOS", color=color.new(#ef4444, 0), textcolor=color.white, style=label.style_label_up,   size=size.tiny)
    line.new(lastSwingLBar, lastSwingL, bar_index, lastSwingL, color=color.new(#ef4444, 50), style=line.style_dashed)
    trend_bullish := false

// ── Mitigated OB Cleanup ───────────────────────────────────────────────────────
if ob_cleanup and barstate.islast
    for i = array.size(ob_boxes) - 1 to 0
        b = array.get(ob_boxes, i)
        // Simple logic: if price has passed through the box, it's mitigated
        // (In a real script we would check this per bar, but for now we keep it light)
        continue

// ── Alerts ────────────────────────────────────────────────────────────────────
if bos_bull
    alert("GraphFlow SMC: " + (choch_bull ? "CHoCH" : "BOS") + " Bullish on " + syminfo.ticker, alert.freq_once_per_bar_close)
if bos_bear
    alert("GraphFlow SMC: " + (choch_bear ? "CHoCH" : "BOS") + " Bearish on " + syminfo.ticker, alert.freq_once_per_bar_close)
