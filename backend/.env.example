# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=graphflow_db
DB_USER=graphflow_user
DB_PASSWORD=graphflow_password
DB_ROOT_PASSWORD=root_password_change_me

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_also_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/graphflow

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_me

# ─── Market Data APIs ────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
YAHOO_FINANCE_RAPID_API_KEY=your_rapid_api_key

# ─── Email ───────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=GraphFlow <no-reply@graphflow.app>

# ─── Bull Queue ──────────────────────────────────────────────────────────────
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=redis_password_change_me
