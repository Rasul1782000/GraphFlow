# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── JWT Authentication ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_secure_random_string_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_secure_random_string_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/graphflow

# ─── Redis (Bull queues + caching) ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Market Data APIs ────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=
YAHOO_FINANCE_RAPID_API_KEY=

# ─── Email (optional) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GraphFlow <no-reply@graphflow.app>
